# ---- Core ----
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Neon Postgres pooled connection string (add ?sslmode=require in production)
DATABASE_URL=postgres://user:pass@localhost:5432/fbm

# Session signing + cookie security
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false
# Set to "none" when web and API are on different sites (e.g. separate
# *.onrender.com subdomains). "none" also forces Secure cookies.
COOKIE_SAMESITE=lax

# Comma-separated allowed web origins
CORS_ORIGIN=http://localhost:5173

# Public URL of the web app — used to build invite links in emails.
# Defaults to the first CORS_ORIGIN entry when unset.
APP_URL=http://localhost:5173

# ---- Optional integrations (features degrade gracefully if unset) ----
SENTRY_DSN=

# Email / SMTP — required for invite emails to actually be delivered.
# Leave SMTP_HOST/SMTP_PORT blank to skip sending (the invite still works via
# the acceptUrl returned by POST /users/invite). Use port 465 for implicit TLS
# or 587 for STARTTLS. Examples:
#   SendGrid : SMTP_HOST=smtp.sendgrid.net   SMTP_PORT=587  SMTP_USER=apikey            SMTP_PASS=<api-key>
#   Resend   : SMTP_HOST=smtp.resend.com     SMTP_PORT=465  SMTP_USER=resend            SMTP_PASS=<api-key>
#   Mailgun  : SMTP_HOST=smtp.mailgun.org    SMTP_PORT=587  SMTP_USER=postmaster@<dom>  SMTP_PASS=<smtp-pass>
#   Gmail    : SMTP_HOST=smtp.gmail.com      SMTP_PORT=587  SMTP_USER=<you@gmail.com>   SMTP_PASS=<app-password>
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Must be a domain you're authorized to send from (SPF/DKIM) or mail lands in spam.
SMTP_FROM=Priceobo <no-reply@priceobo.com>

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ---- Amazon SP-API (LWA). Without these the stub provider is used. ----
# Names match the legacy price-scheduling-server / its Render env, so the
# current values copy across 1:1. invalid_client (401) = LWA_CLIENT_SECRET is
# wrong/stale; invalid_grant (400) = REFRESH_TOKEN is expired.
REFRESH_TOKEN=
LWA_APP_ID=
LWA_CLIENT_SECRET=
SELLER_ID=
MARKETPLACE_ID=
SPAPI_ENDPOINT=https://sellingpartnerapi-na.amazon.com
