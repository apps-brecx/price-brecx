# ---- Core ----
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Neon Postgres pooled connection string (add ?sslmode=require in production)
DATABASE_URL=postgres://user:pass@localhost:5432/fbm

# Session signing + cookie security
SESSION_SECRET=change-me-to-a-long-random-string
COOKIE_SECURE=false
# Set to "none" when web and API are on different sites (e.g. separate
# *.onrender.com subdomains). "none" also forces Secure cookies.
COOKIE_SAMESITE=lax

# Comma-separated allowed web origins
CORS_ORIGIN=http://localhost:5173

# ---- Optional integrations (features degrade gracefully if unset) ----
SENTRY_DSN=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Priceobo <no-reply@priceobo.com>

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ---- Amazon SP-API (LWA). Without these the stub provider is used. ----
SPAPI_REFRESH_TOKEN=
SPAPI_LWA_APP_ID=
SPAPI_LWA_CLIENT_SECRET=
SPAPI_SELLER_ID=
SPAPI_MARKETPLACE_ID=
SPAPI_ENDPOINT=https://sellingpartnerapi-na.amazon.com
