{
  "name": "@fbm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(api) no lint\"",
    "db:migrate": "node-pg-migrate up -m migrations -j js --no-lock",
    "db:migrate:down": "node-pg-migrate down -m migrations -j js --no-lock",
    "db:migrate:create": "node-pg-migrate create -m migrations -j js",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.667.0",
    "@aws-sdk/s3-request-presigner": "^3.667.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "@fbm/shared": "workspace:*",
    "@sentry/node": "^8.33.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "nodemailer": "^6.9.15",
    "pg-boss": "^10.1.5",
    "pino": "^9.4.0",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.16.11",
    "@types/nodemailer": "^6.4.16",
    "node-pg-migrate": "^7.7.1",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
