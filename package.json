{
  "name": "fbm-priceobo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @fbm/api run db:migrate",
    "db:migrate:create": "pnpm --filter @fbm/api run db:migrate:create",
    "db:seed": "pnpm --filter @fbm/api run db:seed",
    "start:api": "pnpm --filter @fbm/api run start"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
